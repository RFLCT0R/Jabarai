<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tool Detail - Neuralist</title>
    <link rel="icon" type="image/png" href="assets/images/logo.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/styles.css">
    <link rel="stylesheet" href="assets/css/footer-components.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        /* ============================================
           Apple-Inspired Design System
           ============================================ */
        
        :root {
            --apple-bg: #f5f5f7;
            --apple-dark: #1d1d1f;
            --apple-blue: #0071e3;
            --apple-blue-hover: #0077ed;
            --apple-gray: #86868b;
            --apple-light-gray: #d2d2d7;
            --apple-card-bg: rgba(255, 255, 255, 0.8);
            --apple-glass: rgba(255, 255, 255, 0.72);
        }

        * {
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--apple-bg);
            color: var(--apple-dark);
            overflow-x: hidden;
        }

        /* ============================================
           Typography - Apple Style
           ============================================ */
        .hero-headline {
            font-size: 80px;
            font-weight: 700;
            letter-spacing: -0.03em;
            line-height: 1.05;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #1d1d1f 0%, #434344 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-subhead {
            font-size: 28px;
            font-weight: 400;
            letter-spacing: -0.02em;
            color: var(--apple-gray);
            line-height: 1.4;
        }

        .section-headline {
            font-size: 48px;
            font-weight: 700;
            letter-spacing: -0.02em;
            line-height: 1.1;
            margin-bottom: 40px;
        }

        .section-subhead {
            font-size: 21px;
            font-weight: 400;
            color: var(--apple-gray);
            line-height: 1.5;
            max-width: 600px;
        }

        /* ============================================
           Animations
           ============================================ */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeScale {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        @keyframes shimmer {
            0% { background-position: -1000px 0; }
            100% { background-position: 1000px 0; }
        }

        @keyframes pulse-subtle {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.02); opacity: 0.9; }
        }

        @keyframes slideShowIn {
            0% {
                opacity: 0;
                transform: scale(1.05) translateY(20px);
            }
            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .animate-fade-up {
            animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }

        .animate-delay-1 { animation-delay: 0.1s; }
        .animate-delay-2 { animation-delay: 0.2s; }
        .animate-delay-3 { animation-delay: 0.3s; }
        .animate-delay-4 { animation-delay: 0.4s; }

        /* ============================================
           Navigation - Apple Style
           ============================================ */
        .nav-glass {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 52px;
            background: rgba(255, 255, 255, 0.72);
            backdrop-filter: saturate(180%) blur(20px);
            -webkit-backdrop-filter: saturate(180%) blur(20px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            transition: all 0.3s ease;
        }

        .nav-glass.scrolled {
            background: rgba(255, 255, 255, 0.88);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
        }

        .nav-logo {
            font-size: 21px;
            font-weight: 600;
            letter-spacing: -0.5px;
            color: var(--apple-dark);
            text-decoration: none;
        }

        .nav-links {
            display: flex;
            gap: 32px;
        }

        .nav-links a {
            font-size: 14px;
            font-weight: 400;
            color: var(--apple-dark);
            text-decoration: none;
            opacity: 0.8;
            transition: opacity 0.3s ease;
        }

        .nav-links a:hover {
            opacity: 1;
        }

        .nav-cta {
            background: var(--apple-blue);
            color: white;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .nav-cta:hover {
            background: var(--apple-blue-hover);
            transform: scale(1.02);
        }

        /* ============================================
           Hero Section
           ============================================ */
        .hero-section {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 140px 40px 80px;
            background: linear-gradient(180deg, #f5f5f7 0%, #ffffff 50%, #f5f5f7 100%);
            position: relative;
            overflow: hidden;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 70%, rgba(0, 113, 227, 0.08) 0%, transparent 50%),
                        radial-gradient(circle at 70% 30%, rgba(0, 113, 227, 0.05) 0%, transparent 40%);
            animation: float 20s ease-in-out infinite;
            pointer-events: none;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(0, 113, 227, 0.1);
            color: var(--apple-blue);
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 30px;
            animation: fadeUp 0.6s ease forwards;
        }

        .hero-logo {
            width: 160px;
            height: 160px;
            object-fit: contain;
            margin-bottom: 40px;
            filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.15));
            animation: float 6s ease-in-out infinite;
        }

        .hero-actions {
            display: flex;
            gap: 20px;
            margin-top: 40px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn-primary {
            background: var(--apple-blue);
            color: white;
            padding: 16px 32px;
            border-radius: 30px;
            font-size: 17px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 4px 20px rgba(0, 113, 227, 0.3);
        }

        .btn-primary:hover {
            background: var(--apple-blue-hover);
            transform: scale(1.02);
            box-shadow: 0 8px 30px rgba(0, 113, 227, 0.4);
        }

        .btn-secondary {
            background: transparent;
            color: var(--apple-blue);
            padding: 16px 32px;
            border-radius: 30px;
            font-size: 17px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 2px solid var(--apple-blue);
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .btn-secondary:hover {
            background: rgba(0, 113, 227, 0.05);
            transform: scale(1.02);
        }

        /* ============================================
           Bento Grid - Apple Style
           ============================================ */
        .bento-section {
            padding: 100px 40px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .bento-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .bento-card {
            background: var(--apple-card-bg);
            border-radius: 24px;
            padding: 32px;
            position: relative;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            border: 1px solid rgba(0, 0, 0, 0.04);
            backdrop-filter: blur(20px);
        }

        .bento-card:hover {
            transform: scale(1.02);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        }

        .bento-card.large {
            grid-column: span 2;
            grid-row: span 2;
        }

        .bento-card.wide {
            grid-column: span 2;
        }

        .bento-card.dark {
            background: var(--apple-dark);
            color: white;
        }

        .bento-card.dark .bento-title {
            color: white;
        }

        .bento-card.dark .bento-text {
            color: rgba(255, 255, 255, 0.7);
        }

        .bento-icon {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, var(--apple-blue) 0%, #0051a3 100%);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            margin-bottom: 20px;
        }

        .bento-title {
            font-size: 24px;
            font-weight: 600;
            letter-spacing: -0.02em;
            margin-bottom: 12px;
            color: var(--apple-dark);
        }

        .bento-text {
            font-size: 15px;
            line-height: 1.6;
            color: var(--apple-gray);
        }

        /* ============================================
           Gallery Section - Apple Style
           ============================================ */
        .gallery-section {
            padding: 100px 0;
            background: linear-gradient(180deg, #f5f5f7 0%, #ffffff 50%, #f5f5f7 100%);
            overflow: hidden;
        }

        .gallery-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 40px;
        }

        .gallery-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .gallery-showcase {
            position: relative;
            height: 600px;
            border-radius: 32px;
            overflow: hidden;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.2);
        }

        .gallery-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            visibility: hidden;
            transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .gallery-slide.active {
            opacity: 1;
            visibility: visible;
        }

        .gallery-slide img {
            max-width: 90%;
            max-height: 80%;
            object-fit: contain;
            filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.4));
            transition: transform 0.5s ease;
        }

        .gallery-slide.active img {
            animation: slideShowIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .gallery-caption {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            text-align: center;
            color: white;
            opacity: 0;
            transition: opacity 0.5s ease 0.3s;
        }

        .gallery-slide.active .gallery-caption {
            opacity: 1;
        }

        .gallery-caption h3 {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .gallery-caption p {
            font-size: 15px;
            opacity: 0.7;
        }

        .gallery-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 48px;
            height: 48px;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            border: none;
            border-radius: 50%;
            color: white;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 10;
        }

        .gallery-nav:hover {
            background: rgba(255, 255, 255, 0.35);
            transform: translateY(-50%) scale(1.1);
        }

        .gallery-nav.prev { left: 30px; }
        .gallery-nav.next { right: 30px; }

        .gallery-dots {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 8px;
            z-index: 10;
        }

        .gallery-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .gallery-dot.active {
            background: white;
            width: 24px;
            border-radius: 4px;
        }

        .gallery-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: var(--apple-blue);
            width: 0%;
            transition: width 0.1s linear;
        }

        /* ============================================
           Info Cards Section
           ============================================ */
        .info-section {
            padding: 100px 40px;
            background: white;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .info-card {
            background: var(--apple-bg);
            border-radius: 20px;
            padding: 28px;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .info-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        }

        .info-value {
            font-size: 36px;
            font-weight: 700;
            color: var(--apple-dark);
            margin-bottom: 8px;
            letter-spacing: -0.02em;
        }

        .info-label {
            font-size: 13px;
            color: var(--apple-gray);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ============================================
           Pricing Section - Apple Style
           ============================================ */
        .pricing-section {
            padding: 100px 40px;
            background: linear-gradient(180deg, #f5f5f7 0%, #ffffff 100%);
        }

        .pricing-container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 60px;
        }

        .pricing-card {
            background: white;
            border-radius: 24px;
            padding: 40px 30px;
            text-align: center;
            border: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
        }

        .pricing-card.featured {
            background: var(--apple-dark);
            color: white;
            transform: scale(1.05);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
        }

        .pricing-card.featured .pricing-name,
        .pricing-card.featured .pricing-price,
        .pricing-card.featured .pricing-cycle {
            color: white;
        }

        .pricing-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
        }

        .pricing-card.featured:hover {
            transform: scale(1.05) translateY(-10px);
        }

        .pricing-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            background: var(--apple-blue);
            color: white;
            padding: 6px 12px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
        }

        .pricing-name {
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--apple-gray);
            margin-bottom: 16px;
        }

        .pricing-price {
            font-size: 48px;
            font-weight: 700;
            color: var(--apple-dark);
            letter-spacing: -0.02em;
            margin-bottom: 4px;
        }

        .pricing-cycle {
            font-size: 15px;
            color: var(--apple-gray);
            margin-bottom: 24px;
        }

        /* ============================================
           CTA Section
           ============================================ */
        .cta-section {
            padding: 120px 40px;
            background: var(--apple-dark);
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .cta-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 50% 50%, rgba(0, 113, 227, 0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .cta-headline {
            font-size: 56px;
            font-weight: 700;
            color: white;
            letter-spacing: -0.02em;
            margin-bottom: 20px;
            position: relative;
        }

        .cta-subhead {
            font-size: 21px;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 40px;
            position: relative;
        }

        .btn-cta {
            background: white;
            color: var(--apple-dark);
            padding: 18px 36px;
            border-radius: 30px;
            font-size: 17px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
        }

        .btn-cta:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 40px rgba(255, 255, 255, 0.3);
        }

        /* ============================================
           Footer - Apple Style
           ============================================ */
        .footer-minimal {
            background: var(--apple-bg);
            padding: 40px;
            border-top: 1px solid rgba(0, 0, 0, 0.05);
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .footer-links {
            display: flex;
            gap: 24px;
        }

        .footer-links a {
            font-size: 12px;
            color: var(--apple-gray);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-links a:hover {
            color: var(--apple-dark);
        }

        .footer-copyright {
            font-size: 12px;
            color: var(--apple-gray);
        }

        /* ============================================
           Loading State
           ============================================ */
        .loading-container {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: var(--apple-bg);
        }

        .loading-spinner {
            width: 48px;
            height: 48px;
            border: 3px solid rgba(0, 113, 227, 0.1);
            border-top-color: var(--apple-blue);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .loading-text {
            margin-top: 20px;
            font-size: 15px;
            color: var(--apple-gray);
        }

        /* ============================================
           Responsive Design
           ============================================ */
        @media (max-width: 1024px) {
            .hero-headline {
                font-size: 56px;
            }

            .bento-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .bento-card.large {
                grid-column: span 2;
                grid-row: span 1;
            }

            .info-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .pricing-grid {
                grid-template-columns: 1fr;
            }

            .pricing-card.featured {
                transform: none;
            }

            .pricing-card.featured:hover {
                transform: translateY(-10px);
            }
        }

        @media (max-width: 768px) {
            .hero-headline {
                font-size: 40px;
            }

            .hero-subhead {
                font-size: 21px;
            }

            .section-headline {
                font-size: 32px;
            }

            .nav-glass {
                padding: 0 20px;
            }

            .nav-links {
                display: none;
            }

            .bento-grid {
                grid-template-columns: 1fr;
            }

            .bento-card.large,
            .bento-card.wide {
                grid-column: span 1;
            }

            .gallery-showcase {
                height: 400px;
            }

            .info-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .cta-headline {
                font-size: 36px;
            }

            .footer-content {
                flex-direction: column;
                text-align: center;
            }
        }

        /* Scroll Reveal Animation */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="nav-glass" id="navbar">
        <a href="index.html" class="nav-logo">Neuralist.</a>
        <div class="nav-links">
            <a href="index.html">Home</a>
            <a href="about.html">About</a>
            <a href="contact.html">Contact</a>
        </div>
        <a href="index.html" class="nav-cta">Explore Tools</a>
    </nav>

    <!-- Main Content -->
    <main id="main-content">
        <!-- Loading State -->
        <div class="loading-container" id="loading">
            <div class="loading-spinner"></div>
            <p class="loading-text">Loading...</p>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer-minimal">
        <div class="footer-content">
            <div class="footer-links">
                <a href="index.html">Home</a>
                <a href="about.html">About</a>
                <a href="contact.html">Contact</a>
                <a href="privacy-policy.html">Privacy</a>
                <a href="terms-of-use.html">Terms</a>
            </div>
            <p class="footer-copyright">© 2026 Neuralist. All rights reserved.</p>
        </div>
    </footer>

    <script>
        // Helper functions
        function formatDate(dateString) {
            if (!dateString) return 'N/A';
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
        }

        function formatNumber(num) {
            if (!num) return '0';
            if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
            if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
            return num.toString();
        }

        function renderStars(rating) {
            const fullStars = Math.floor(rating || 0);
            const hasHalfStar = (rating || 0) % 1 >= 0.5;
            let starsHtml = '';
            for (let i = 0; i < fullStars; i++) {
                starsHtml += '<i class="fas fa-star"></i>';
            }
            if (hasHalfStar) {
                starsHtml += '<i class="fas fa-star-half-alt"></i>';
            }
            const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
            for (let i = 0; i < emptyStars; i++) {
                starsHtml += '<i class="far fa-star"></i>';
            }
            return starsHtml;
        }

        // Navigation scroll effect
        function initNavScroll() {
            const navbar = document.getElementById('navbar');
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) {
                    navbar.classList.add('scrolled');
                } else {
                    navbar.classList.remove('scrolled');
                }
            });
        }

        // Scroll reveal animations
        function initScrollReveal() {
            const reveals = document.querySelectorAll('.reveal');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

            reveals.forEach(el => observer.observe(el));
        }

        // Gallery slideshow
        let currentSlide = 0;
        let slideshowInterval;
        let progressInterval;
        const SLIDE_DURATION = 6000;

        function initSlideshow() {
            const slides = document.querySelectorAll('.gallery-slide');
            const dots = document.querySelectorAll('.gallery-dot');
            
            if (slides.length === 0) return;

            function showSlide(index) {
                slides[currentSlide].classList.remove('active');
                dots[currentSlide].classList.remove('active');
                
                currentSlide = index;
                if (currentSlide >= slides.length) currentSlide = 0;
                if (currentSlide < 0) currentSlide = slides.length - 1;
                
                slides[currentSlide].classList.add('active');
                dots[currentSlide].classList.add('active');
                
                resetProgress();
                startProgress();
            }

            window.changeSlide = (dir) => {
                stopSlideshow();
                showSlide(currentSlide + dir);
                startSlideshow();
            };

            window.goToSlide = (index) => {
                stopSlideshow();
                showSlide(index);
                startSlideshow();
            };

            startSlideshow();
        }

        function startSlideshow() {
            stopSlideshow();
            slideshowInterval = setInterval(() => {
                window.changeSlide(1);
            }, SLIDE_DURATION);
            startProgress();
        }

        function stopSlideshow() {
            if (slideshowInterval) clearInterval(slideshowInterval);
            if (progressInterval) clearInterval(progressInterval);
        }

        function startProgress() {
            const progress = document.getElementById('galleryProgress');
            if (!progress) return;
            
            let width = 0;
            const increment = 100 / (SLIDE_DURATION / 50);
            
            progressInterval = setInterval(() => {
                width += increment;
                if (width >= 100) width = 0;
                progress.style.width = width + '%';
            }, 50);
        }

        function resetProgress() {
            const progress = document.getElementById('galleryProgress');
            if (progress) progress.style.width = '0%';
        }

        // Render tool page
        function renderTool(tool) {
            const websiteUrl = tool.websiteUrl || '#';
            const hasImages = tool.imageDescriptions && tool.imageDescriptions.length > 0;
            
            const html = `
                <!-- Hero Section -->
                <section class="hero-section">
                    <div class="hero-badge animate-fade-up">
                        <i class="fas fa-star"></i>
                        ${tool.rating || '4.5'} Rating · ${tool.category}
                    </div>
                    
                    <img src="${tool.logo}" alt="${tool.name}" class="hero-logo" 
                         onerror="this.src='assets/images/logo.png'">
                    
                    <h1 class="hero-headline animate-fade-up animate-delay-1">${tool.name}</h1>
                    <p class="hero-subhead animate-fade-up animate-delay-2">
                        ${tool.shortDescription || tool.fullDescription || 'AI-powered tool for modern workflows'}
                    </p>
                    
                    <div class="hero-actions animate-fade-up animate-delay-3">
                        <a href="${websiteUrl}" target="_blank" class="btn-primary">
                            <i class="fas fa-external-link-alt"></i> Visit Website
                        </a>
                        <a href="index.html" class="btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Directory
                        </a>
                    </div>
                </section>

                <!-- Info Cards -->
                <section class="info-section">
                    <div class="info-grid reveal">
                        <div class="info-card">
                            <div class="info-value">${tool.rating || '4.5'}</div>
                            <div class="info-label">Rating</div>
                        </div>
                        <div class="info-card">
                            <div class="info-value">${formatNumber(tool.totalReviews || 0)}</div>
                            <div class="info-label">Reviews</div>
                        </div>
                        <div class="info-card">
                            <div class="info-value">${tool.pricing || 'Free'}</div>
                            <div class="info-label">Pricing</div>
                        </div>
                        <div class="info-card">
                            <div class="info-value">${formatDate(tool.releaseDate) || '2024'}</div>
                            <div class="info-label">Launched</div>
                        </div>
                    </div>
                </section>

                <!-- Bento Grid Features -->
                <section class="bento-section">
                    <div class="reveal" style="text-align: center; margin-bottom: 60px;">
                        <h2 class="section-headline">Everything you need.</h2>
                        <p class="section-subhead" style="margin: 0 auto;">
                            Powerful features designed for modern workflows.
                        </p>
                    </div>
                    
                    <div class="bento-grid">
                        ${tool.features && tool.features.length > 0 ? tool.features.slice(0, 6).map((feature, i) => `
                            <div class="bento-card ${i === 0 ? 'large dark' : ''} reveal">
                                <div class="bento-icon">
                                    <i class="fas fa-${i === 0 ? 'bolt' : i === 1 ? 'brain' : i === 2 ? 'magic' : i === 3 ? 'shield-alt' : i === 4 ? 'rocket' : 'cog'}"></i>
                                </div>
                                <h3 class="bento-title">${feature}</h3>
                                <p class="bento-text">
                                    ${i === 0 ? 'Lightning-fast performance with optimized algorithms.' : 
                                      i === 1 ? 'AI-powered intelligence for smarter results.' :
                                      i === 2 ? 'Seamless integration with your favorite tools.' :
                                      i === 3 ? 'Enterprise-grade security and privacy.' :
                                      i === 4 ? 'Scale effortlessly as you grow.' :
                                      'Customizable workflows for any team.'}
                                </p>
                            </div>
                        `).join('') : `
                            <div class="bento-card large dark reveal">
                                <div class="bento-icon"><i class="fas fa-bolt"></i></div>
                                <h3 class="bento-title">Lightning Fast</h3>
                                <p class="bento-text">Optimized performance for instant results.</p>
                            </div>
                            <div class="bento-card reveal">
                                <div class="bento-icon"><i class="fas fa-brain"></i></div>
                                <h3 class="bento-title">AI Powered</h3>
                                <p class="bento-text">Smart algorithms that learn and adapt.</p>
                            </div>
                            <div class="bento-card reveal">
                                <div class="bento-icon"><i class="fas fa-shield-alt"></i></div>
                                <h3 class="bento-title">Secure</h3>
                                <p class="bento-text">Enterprise-grade security built-in.</p>
                            </div>
                        `}
                    </div>
                </section>

                ${hasImages ? `
                <!-- Gallery Section -->
                <section class="gallery-section">
                    <div class="gallery-container">
                        <div class="gallery-header reveal">
                            <h2 class="section-headline">See it in action.</h2>
                            <p class="section-subhead" style="margin: 0 auto;">
                                Experience the intuitive interface and powerful capabilities.
                            </p>
                        </div>
                        
                        <div class="gallery-showcase reveal">
                            ${tool.imageDescriptions.map((img, index) => `
                                <div class="gallery-slide ${index === 0 ? 'active' : ''}">
                                    <img src="${img.imageUrl}" alt="${img.caption || ''}" 
                                         onerror="this.style.display='none'">
                                    ${img.caption ? `
                                    <div class="gallery-caption">
                                        <h3>Screenshot ${index + 1}</h3>
                                        <p>${img.caption}</p>
                                    </div>
                                    ` : ''}
                                </div>
                            `).join('')}
                            
                            <button class="gallery-nav prev" onclick="changeSlide(-1)">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                            <button class="gallery-nav next" onclick="changeSlide(1)">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                            
                            <div class="gallery-dots">
                                ${tool.imageDescriptions.map((_, index) => `
                                    <button class="gallery-dot ${index === 0 ? 'active' : ''}" 
                                            onclick="goToSlide(${index})"></button>
                                `).join('')}
                            </div>
                            
                            <div class="gallery-progress" id="galleryProgress"></div>
                        </div>
                    </div>
                </section>
                ` : ''}

                ${tool.pricingDetails && tool.pricingDetails.length > 0 ? `
                <!-- Pricing Section -->
                <section class="pricing-section">
                    <div class="pricing-container">
                        <div class="reveal" style="text-align: center; margin-bottom: 60px;">
                            <h2 class="section-headline">Simple pricing.</h2>
                            <p class="section-subhead" style="margin: 0 auto;">
                                Choose the plan that works for you.
                            </p>
                        </div>
                        
                        <div class="pricing-grid">
                            ${tool.pricingDetails.map((plan, index) => `
                                <div class="pricing-card ${index === 1 ? 'featured' : ''} reveal">
                                    ${index === 1 ? '<span class="pricing-badge">Popular</span>' : ''}
                                    <div class="pricing-name">${plan.plan}</div>
                                    <div class="pricing-price">${plan.price}</div>
                                    <div class="pricing-cycle">${plan.billingCycle || ''}</div>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </section>
                ` : ''}

                <!-- CTA Section -->
                <section class="cta-section">
                    <h2 class="cta-headline reveal">Ready to get started?</h2>
                    <p class="cta-subhead reveal">Experience the future of AI-powered workflows.</p>
                    <a href="${websiteUrl}" target="_blank" class="btn-cta reveal">
                        <i class="fas fa-external-link-alt"></i> Visit ${tool.name}
                    </a>
                </section>
            `;

            document.getElementById('main-content').innerHTML = html;
            document.title = `${tool.name} - Neuralist`;
            
            // Initialize interactions
            initScrollReveal();
            if (hasImages) initSlideshow();
        }

        // Load tool data
        async function loadTool() {
            const params = new URLSearchParams(window.location.search);
            const toolId = params.get('id') || params.get('slug');

            if (!toolId) {
                document.getElementById('main-content').innerHTML = `
                    <div class="loading-container">
                        <h2 style="margin-bottom: 20px;">Tool Not Found</h2>
                        <a href="index.html" class="btn-primary">Back to Directory</a>
                    </div>
                `;
                return;
            }

            try {
                const [tools1, tools2, tools3] = await Promise.all([
                    fetch('assets/data/tools1.json').then(r => r.json()).catch(() => []),
                    fetch('assets/data/tools2.json').then(r => r.json()).catch(() => []),
                    fetch('assets/data/tools3.json').then(r => r.json()).catch(() => [])
                ]);

                const allTools = [...tools1, ...tools2, ...tools3];
                const tool = allTools.find(t => t.id === toolId || t.slug === toolId);

                if (!tool) {
                    document.getElementById('main-content').innerHTML = `
                        <div class="loading-container">
                            <h2 style="margin-bottom: 20px;">Tool Not Found</h2>
                            <p style="margin-bottom: 20px; color: var(--apple-gray);">"${toolId}" not found.</p>
                            <a href="index.html" class="btn-primary">Back to Directory</a>
                        </div>
                    `;
                    return;
                }

                renderTool(tool);
            } catch (error) {
                console.error('Error loading tool:', error);
                document.getElementById('main-content').innerHTML = `
                    <div class="loading-container">
                        <h2 style="margin-bottom: 20px;">Error Loading Tool</h2>
                        <a href="index.html" class="btn-primary">Back to Directory</a>
                    </div>
                `;
            }
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            initNavScroll();
            loadTool();
        });
    </script>
</body>
</html>
            width: 100px;
            height: 100px;
            object-fit: contain;
            flex-shrink: 0;
            border-radius: 16px;
            background: white;
            padding: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            animation: scaleIn 0.5s ease-out, float 6s ease-in-out infinite;
            transition: transform 0.3s ease;
        }

        .cv-logo:hover {
            transform: scale(1.1) rotate(5deg);
        }

        .cv-header-info {
            flex: 1;
        }

        .cv-name {
            font-size: 42px;
            font-weight: 800;
            color: #ffffff;
            margin-bottom: 8px;
            letter-spacing: -1px;
            animation: slideInLeft 0.6s ease-out 0.1s both;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        }

        .cv-title {
            font-size: 18px;
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 12px;
            animation: slideInLeft 0.6s ease-out 0.2s both;
        }

        .cv-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.9);
            animation: slideInLeft 0.6s ease-out 0.3s both;
        }

        .cv-meta span {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            backdrop-filter: blur(5px);
            transition: all 0.3s ease;
        }

        .cv-meta span:hover {
            background: rgba(14, 165, 233, 0.3);
            transform: translateY(-2px);
        }

        /* CV Body - Enhanced */
        .cv-body {
            padding: 40px 60px;
        }

        .cv-section {
            margin-bottom: 35px;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.5s ease;
        }

        .cv-section.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .cv-section:last-child {
            margin-bottom: 0;
        }

        .cv-section-title {
            font-size: 14px;
            font-weight: 700;
            color: #1a1a1a;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 2px solid #0ea5e9;
            padding-bottom: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s ease;
        }

        .cv-section-title:hover {
            padding-left: 10px;
            color: #0ea5e9;
        }

        .cv-section-title::before {
            content: '';
            width: 4px;
            height: 16px;
            background: #0ea5e9;
            border-radius: 2px;
        }

        .cv-text {
            font-size: 15px;
            line-height: 1.8;
            color: #374151;
        }

        /* Features Grid - Enhanced */
        .cv-features {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px 30px;
        }

        .cv-feature {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 14px;
            color: #374151;
            padding: 10px;
            border-radius: 8px;
            transition: all 0.3s ease;
            cursor: default;
        }

        .cv-feature:hover {
            background: rgba(14, 165, 233, 0.1);
            transform: translateX(5px);
        }

        .cv-feature i {
            color: #10b981;
            margin-top: 2px;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .cv-feature:hover i {
            transform: scale(1.2);
            color: #0ea5e9;
        }

        /* Use Cases - Enhanced */
        .cv-usecases {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .cv-usecase {
            background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
            padding: 8px 16px;
            font-size: 13px;
            color: #374151;
            border-radius: 20px;
            border: 1px solid transparent;
            transition: all 0.3s ease;
            cursor: default;
        }

        .cv-usecase:hover {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(14, 165, 233, 0.3);
        }

        /* Pros Cons */
        .cv-pros-cons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .cv-pros h4, .cv-cons h4 {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .cv-pros h4 {
            color: #059669;
        }

        .cv-cons h4 {
            color: #dc2626;
        }

        .cv-pros ul, .cv-cons ul {
            list-style: none;
            font-size: 14px;
        }

        .cv-pros li, .cv-cons li {
            padding: 4px 0;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }

        /* Pricing - Enhanced */
        .cv-pricing {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 16px;
        }

        .cv-price-card {
            border: 1px solid #e5e7eb;
            padding: 20px;
            text-align: center;
            border-radius: 12px;
            background: white;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .cv-price-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #0ea5e9, #10b981);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .cv-price-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
        }

        .cv-price-card:hover::before {
            transform: scaleX(1);
        }

        .cv-price-name {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            color: #6b7280;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .cv-price {
            font-size: 24px;
            font-weight: 800;
            color: #1a1a1a;
            margin-bottom: 4px;
        }

        .cv-price-cycle {
            font-size: 12px;
            color: #9ca3af;
        }

        /* Info Grid */
        .cv-info-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .cv-info-item {
            font-size: 14px;
        }

        .cv-info-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #9ca3af;
            margin-bottom: 4px;
        }

        .cv-info-value {
            color: #1a1a1a;
            font-weight: 500;
        }

        /* Screenshots Slideshow - Modern Carousel */
        .cv-screenshots-slideshow {
            position: relative;
            width: 100%;
            height: 400px;
            border-radius: 12px;
            overflow: hidden;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d3748 100%);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .slideshow-container {
            position: relative;
            width: 100%;
            height: 100%;
        }

        .slideshow-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.8s ease, visibility 0.8s ease;
        }

        .slideshow-slide.active {
            opacity: 1;
            visibility: visible;
        }

        .slideshow-slide.animating-in {
            animation: slideShowIn 0.8s ease-out forwards;
        }

        .slideshow-slide.animating-out {
            animation: slideShowOut 0.8s ease-out forwards;
        }

        .slideshow-slide img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            background: rgba(0, 0, 0, 0.3);
        }

        .slideshow-caption {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 30px;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, transparent 100%);
            color: white;
            transform: translateY(100%);
            transition: transform 0.5s ease;
        }

        .slideshow-slide.active .slideshow-caption {
            transform: translateY(0);
            animation: captionSlideUp 0.6s ease-out 0.3s both;
        }

        .slideshow-caption h4 {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 8px;
            color: #0ea5e9;
        }

        .slideshow-caption p {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.9);
            line-height: 1.6;
        }

        .slideshow-indicators {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 8px;
            z-index: 10;
        }

        .slideshow-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.4);
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
        }

        .slideshow-dot:hover {
            background: rgba(255, 255, 255, 0.7);
            transform: scale(1.2);
        }

        .slideshow-dot.active {
            background: #0ea5e9;
            width: 30px;
            border-radius: 5px;
        }

        .slideshow-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 10;
        }

        .slideshow-nav:hover {
            background: #0ea5e9;
            transform: translateY(-50%) scale(1.1);
        }

        .slideshow-nav.prev { left: 20px; }
        .slideshow-nav.next { right: 20px; }

        .slideshow-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 4px;
            background: #0ea5e9;
            width: 0%;
            transition: width 0.1s linear;
            z-index: 10;
        }

        /* FAQ */
        .cv-faq-item {
            margin-bottom: 16px;
            padding-bottom: 16px;
            border-bottom: 1px solid #f3f4f6;
        }

        .cv-faq-item:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: none;
        }

        .cv-faq-question {
            font-weight: 600;
            font-size: 14px;
            color: #1a1a1a;
            margin-bottom: 6px;
        }

        .cv-faq-answer {
            font-size: 14px;
            color: #6b7280;
            line-height: 1.6;
        }

        /* CV Footer - Enhanced */
        .cv-footer {
            padding: 30px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
            border-top: 1px solid #e5e7eb;
        }

        .cv-links {
            display: flex;
            gap: 20px;
        }

        .cv-links a {
            color: #6b7280;
            text-decoration: none;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: all 0.3s ease;
            padding: 8px 12px;
            border-radius: 8px;
        }

        .cv-links a:hover {
            color: #0ea5e9;
            background: rgba(14, 165, 233, 0.1);
            transform: translateX(-3px);
        }

        .cv-visit-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            color: white;
            padding: 14px 28px;
            font-weight: 600;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(14, 165, 233, 0.3);
        }

        .cv-visit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(14, 165, 233, 0.4);
        }

        .cv-visit-btn:active {
            transform: translateY(-1px);
        }

        /* Loading & Error - Enhanced */
        .tool-loading, .tool-error {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 400px;
            text-align: center;
            padding: 40px;
            background: rgba(255, 255, 255, 0.9);
            border-radius: 16px;
            backdrop-filter: blur(10px);
        }

        .tool-loading i {
            color: #0ea5e9;
            animation: pulse 1.5s ease-in-out infinite;
        }

        /* Pros & Cons Enhanced */
        .cv-pros-cons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .cv-pros, .cv-cons {
            padding: 20px;
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .cv-pros {
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(16, 185, 129, 0.1) 100%);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .cv-cons {
            background: linear-gradient(135deg, rgba(220, 38, 38, 0.05) 0%, rgba(220, 38, 38, 0.1) 100%);
            border: 1px solid rgba(220, 38, 38, 0.2);
        }

        .cv-pros:hover, .cv-cons:hover {
            transform: translateY(-5px);
        }

        .cv-pros h4, .cv-cons h4 {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .cv-pros h4 {
            color: #059669;
        }

        .cv-cons h4 {
            color: #dc2626;
        }

        /* FAQ Enhanced */
        .cv-faq-item {
            margin-bottom: 16px;
            padding: 20px;
            border-radius: 12px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            transition: all 0.3s ease;
        }

        .cv-faq-item:hover {
            background: white;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            transform: translateX(5px);
        }

        .cv-faq-item:last-child {
            margin-bottom: 0;
        }

        .cv-faq-question {
            font-weight: 600;
            font-size: 14px;
            color: #1a1a1a;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .cv-faq-question::before {
            content: 'Q:';
            color: #0ea5e9;
            font-weight: 700;
        }

        .cv-faq-answer {
            font-size: 14px;
            color: #6b7280;
            line-height: 1.6;
            padding-left: 24px;
        }

        /* Info Grid Enhanced */
        .cv-info-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .cv-info-item {
            font-size: 14px;
            padding: 15px;
            border-radius: 10px;
            background: #f8fafc;
            transition: all 0.3s ease;
        }

        .cv-info-item:hover {
            background: white;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            transform: translateY(-3px);
        }

        .cv-info-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #9ca3af;
            margin-bottom: 4px;
        }

        .cv-info-value {
            color: #1a1a1a;
            font-weight: 500;
        }

        /* Alternatives Enhanced */
        .cv-alternatives a {
            display: inline-block;
            padding: 6px 12px;
            margin: 4px;
            background: #f3f4f6;
            border-radius: 6px;
            transition: all 0.3s ease;
        }

        .cv-alternatives a:hover {
            background: #0ea5e9;
            color: white;
            transform: translateY(-2px);
        }

        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(14, 165, 233, 0.4);
            z-index: 1000;
            border: none;
        }

        .back-to-top.visible {
            opacity: 1;
            visibility: visible;
        }

        .back-to-top:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(14, 165, 233, 0.5);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .cv-header {
                flex-direction: column;
                text-align: center;
                padding: 30px;
            }

            .cv-name {
                font-size: 28px;
            }

            .cv-body {
                padding: 30px;
            }

            .cv-features, .cv-pros-cons, .cv-info-grid {
                grid-template-columns: 1fr;
            }

            .cv-footer {
                flex-direction: column;
                gap: 20px;
                padding: 30px;
            }

            .cv-screenshots-slideshow {
                height: 250px;
            }

            .slideshow-nav {
                width: 40px;
                height: 40px;
            }
        }
    </style>
</head>
<body>
    <!-- Site Toolbar -->
    <header class="toolbar">
        <a href="index.html" class="logo">
            <span style="color: #1a1a1a;">Neuralist</span><span style="color: #0ea5e9;">.</span>
        </a>
        <nav class="nav-links">
            <a href="index.html">Home</a>
            <a href="about.html">About</a>
            <a href="contact.html">Contact</a>
        </nav>
        <div class="nav-actions">
            <button class="btn-signup">Get Started</button>
            <div class="account-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
            </div>
        </div>
    </header>

    <main class="tool-cv-wrapper">
        <div class="tool-cv-container">
            <div id="tool-cv">
                <div class="tool-loading">
                    <i class="fas fa-spinner fa-spin fa-2x" style="margin-bottom: 16px;"></i>
                    <p>Loading tool information...</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Site Footer -->
    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-main">
                <div class="footer-brand">
                    <a href="index.html" class="footer-logo">
                        <span style="color: #ffffff;">Neuralist</span><span style="color: #0ea5e9;">.</span>
                    </a>
                    <p class="footer-tagline">Discover the best AI tools, all in one place.</p>
                </div>
                <div class="footer-column">
                    <h4>Explore</h4>
                    <ul>
                        <li><a href="index.html">Home</a></li>
                        <li><a href="about.html">About Us</a></li>
                        <li><a href="contact.html">Contact Us</a></li>
                        <li><a href="privacy-policy.html">Privacy Policy</a></li>
                        <li><a href="terms-of-use.html">Terms of Use</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Company</h4>
                    <ul>
                        <li><a href="about.html">About Us</a></li>
                        <li><a href="contact.html">Contact Us</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Legal</h4>
                    <ul>
                        <li><a href="privacy-policy.html">Privacy Policy</a></li>
                        <li><a href="terms-of-use.html">Terms of Use</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p class="footer-copyright">© 2026 Neuralist. All rights reserved.</p>
                <div class="footer-bottom-social">
                    <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                    <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#" aria-label="GitHub"><i class="fab fa-github"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Back to Top Button -->
    <button class="back-to-top" id="backToTop" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
        <i class="fas fa-arrow-up"></i>
    </button>

    <script>
        // Helper functions
        function formatDate(dateString) {
            if (!dateString) return 'N/A';
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
        }

        function formatNumber(num) {
            if (!num) return '0';
            if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
            if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
            return num.toString();
        }

        function renderStars(rating) {
            const fullStars = Math.floor(rating || 0);
            const hasHalfStar = (rating || 0) % 1 >= 0.5;
            let starsHtml = '';
            for (let i = 0; i < fullStars; i++) {
                starsHtml += '<i class="fas fa-star"></i>';
            }
            if (hasHalfStar) {
                starsHtml += '<i class="fas fa-star-half-alt"></i>';
            }
            const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
            for (let i = 0; i < emptyStars; i++) {
                starsHtml += '<i class="far fa-star"></i>';
            }
            return starsHtml;
        }

        function getPlatformIcon(platform) {
            const icons = {
                'Web': 'fa-globe',
                'iOS': 'fa-apple',
                'Android': 'fa-android',
                'Windows': 'fa-windows',
                'Mac': 'fa-apple',
                'Linux': 'fa-linux',
                'API': 'fa-code'
            };
            return icons[platform] || 'fa-circle';
        }

        // Render the tool CV
        function renderTool(tool) {
            const websiteUrl = tool.websiteUrl || '#';
            const affiliateUrl = tool.affiliateLink || websiteUrl;
            
            let html = `
                <div class="tool-cv">
                    <!-- CV Header -->
                    <div class="cv-header">
                        <img src="${tool.logo}" alt="${tool.name}" class="cv-logo" onerror="this.src='assets/images/logo.png'">
                        <div class="cv-header-info">
                            <h1 class="cv-name">${tool.name}</h1>
                            <div class="cv-title">${tool.category} by ${tool.company}</div>
                            <div class="cv-meta">
                                <span><i class="fas fa-star" style="color: #f59e0b;"></i> ${tool.rating || 'N/A'} (${formatNumber(tool.totalReviews)} reviews)</span>
                                <span><i class="fas fa-tag"></i> ${tool.pricing}</span>
                                <span><i class="fas fa-calendar"></i> Released ${formatDate(tool.releaseDate)}</span>
                                ${tool.hasFreeTier ? '<span><i class="fas fa-check" style="color: #10b981;"></i> Free tier available</span>' : ''}
                            </div>
                        </div>
                    </div>

                    <!-- CV Body -->
                    <div class="cv-body">
                        <!-- About -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Profile</h3>
                            <p class="cv-text">${tool.fullDescription || tool.shortDescription}</p>
                        </div>

                        ${tool.features && tool.features.length > 0 ? `
                        <!-- Features -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Key Capabilities</h3>
                            <div class="cv-features">
                                ${tool.features.map(f => `<div class="cv-feature"><i class="fas fa-check-circle"></i> ${f}</div>`).join('')}
                            </div>
                        </div>
                        ` : ''}

                        ${tool.useCases && tool.useCases.length > 0 ? `
                        <!-- Use Cases -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Use Cases</h3>
                            <div class="cv-usecases">
                                ${tool.useCases.map(u => `<span class="cv-usecase">${u}</span>`).join('')}
                            </div>
                        </div>
                        ` : ''}

                        ${((tool.pros && tool.pros.length > 0) || (tool.cons && tool.cons.length > 0)) ? `
                        <!-- Pros & Cons -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Evaluation</h3>
                            <div class="cv-pros-cons">
                                ${tool.pros && tool.pros.length > 0 ? `
                                <div class="cv-pros">
                                    <h4><i class="fas fa-thumbs-up"></i> Strengths</h4>
                                    <ul>
                                        ${tool.pros.map(p => `<li><i class="fas fa-plus" style="color: #059669; font-size: 8px; margin-top: 6px;"></i> ${p}</li>`).join('')}
                                    </ul>
                                </div>
                                ` : ''}
                                ${tool.cons && tool.cons.length > 0 ? `
                                <div class="cv-cons">
                                    <h4><i class="fas fa-thumbs-down"></i> Limitations</h4>
                                    <ul>
                                        ${tool.cons.map(c => `<li><i class="fas fa-minus" style="color: #dc2626; font-size: 8px; margin-top: 6px;"></i> ${c}</li>`).join('')}
                                    </ul>
                                </div>
                                ` : ''}
                            </div>
                        </div>
                        ` : ''}

                        ${tool.pricingDetails && tool.pricingDetails.length > 0 ? `
                        <!-- Pricing -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Pricing</h3>
                            <div class="cv-pricing">
                                ${tool.pricingDetails.map(plan => `
                                    <div class="cv-price-card">
                                        <div class="cv-price-name">${plan.plan}</div>
                                        <div class="cv-price">${plan.price}</div>
                                        <div class="cv-price-cycle">${plan.billingCycle || ''}</div>
                                    </div>
                                `).join('')}
                            </div>
                        </div>
                        ` : ''}

                        <!-- Technical Info -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Technical Details</h3>
                            <div class="cv-info-grid">
                                ${tool.platform && tool.platform.length > 0 ? `
                                <div class="cv-info-item">
                                    <div class="cv-info-label">Platforms</div>
                                    <div class="cv-info-value">${tool.platform.join(', ')}</div>
                                </div>
                                ` : ''}
                                ${tool.language && tool.language.length > 0 ? `
                                <div class="cv-info-item">
                                    <div class="cv-info-label">Languages</div>
                                    <div class="cv-info-value">${tool.language.join(', ')}</div>
                                </div>
                                ` : ''}
                                ${tool.integrations && tool.integrations.length > 0 ? `
                                <div class="cv-info-item">
                                    <div class="cv-info-label">Integrations</div>
                                    <div class="cv-info-value">${tool.integrations.slice(0, 5).join(', ')}${tool.integrations.length > 5 ? '...' : ''}</div>
                                </div>
                                ` : ''}
                                <div class="cv-info-item">
                                    <div class="cv-info-label">API Access</div>
                                    <div class="cv-info-value">${tool.apiAvailable ? 'Yes' : 'No'}</div>
                                </div>
                                ${tool.dataResidency ? `
                                <div class="cv-info-item">
                                    <div class="cv-info-label">Data Location</div>
                                    <div class="cv-info-value">${tool.dataResidency}</div>
                                </div>
                                ` : ''}
                                ${tool.gdprCompliant || tool.soc2Compliant ? `
                                <div class="cv-info-item">
                                    <div class="cv-info-label">Compliance</div>
                                    <div class="cv-info-value">
                                        ${tool.gdprCompliant ? 'GDPR' : ''}
                                        ${tool.gdprCompliant && tool.soc2Compliant ? ', ' : ''}
                                        ${tool.soc2Compliant ? 'SOC 2' : ''}
                                    </div>
                                </div>
                                ` : ''}
                            </div>
                        </div>

                        ${tool.imageDescriptions && tool.imageDescriptions.length > 0 ? `
                        <!-- Screenshots Slideshow -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Screenshots</h3>
                            <div class="cv-screenshots-slideshow" id="screenshotSlideshow">
                                <div class="slideshow-container">
                                    ${tool.imageDescriptions.map((img, index) => `
                                        <div class="slideshow-slide ${index === 0 ? 'active' : ''}" data-index="${index}">
                                            <img src="${img.imageUrl}" alt="${img.caption || ''}" onerror="this.style.display='none'">
                                            ${img.caption ? `
                                            <div class="slideshow-caption">
                                                <h4>Screenshot ${index + 1}</h4>
                                                <p>${img.caption}</p>
                                            </div>
                                            ` : ''}
                                        </div>
                                    `).join('')}
                                </div>
                                <button class="slideshow-nav prev" onclick="changeSlide(-1)"><i class="fas fa-chevron-left"></i></button>
                                <button class="slideshow-nav next" onclick="changeSlide(1)"><i class="fas fa-chevron-right"></i></button>
                                <div class="slideshow-indicators">
                                    ${tool.imageDescriptions.map((_, index) => `
                                        <button class="slideshow-dot ${index === 0 ? 'active' : ''}" onclick="goToSlide(${index})"></button>
                                    `).join('')}
                                </div>
                                <div class="slideshow-progress" id="slideshowProgress"></div>
                            </div>
                        </div>
                        ` : ''}

                        ${tool.faq && tool.faq.length > 0 ? `
                        <!-- FAQ -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Common Questions</h3>
                            <div>
                                ${tool.faq.map(item => `
                                    <div class="cv-faq-item">
                                        <div class="cv-faq-question">Q: ${item.question}</div>
                                        <div class="cv-faq-answer">${item.answer}</div>
                                    </div>
                                `).join('')}
                            </div>
                        </div>
                        ` : ''}

                        ${tool.alternatives && tool.alternatives.length > 0 ? `
                        <!-- Alternatives -->
                        <div class="cv-section">
                            <h3 class="cv-section-title">Alternatives</h3>
                            <p class="cv-text cv-alternatives">
                                ${tool.alternatives.map(alt => `<a href="tool.html?id=${alt.slug}">${alt.name}</a>`).join('')}
                            </p>
                        </div>
                        ` : ''}
                    </div>

                    <!-- CV Footer -->
                    <div class="cv-footer">
                        <div class="cv-links">
                            <a href="index.html"><i class="fas fa-arrow-left"></i> Back to Directory</a>
                            ${tool.affiliateProgram && tool.affiliateDetails ? `<a href="${affiliateUrl}" target="_blank"><i class="fas fa-handshake"></i> Affiliate: ${tool.affiliateDetails.commission}</a>` : ''}
                        </div>
                        <a href="${websiteUrl}" target="_blank" class="cv-visit-btn">
                            <i class="fas fa-external-link-alt"></i> Visit Website
                        </a>
                    </div>
                </div>
            `;

            document.getElementById('tool-cv').innerHTML = html;
            document.title = `${tool.name} | Neuralist`;
            
            // Initialize slideshow if images exist
            if (tool.imageDescriptions && tool.imageDescriptions.length > 0) {
                initSlideshow();
            }
            
            // Initialize scroll animations
            initScrollAnimations();
        }

        // Slideshow functionality
        let currentSlide = 0;
        let slideshowInterval;
        let progressInterval;
        const SLIDE_DURATION = 6000; // 6 seconds

        function initSlideshow() {
            currentSlide = 0;
            startSlideshow();
        }

        function showSlide(index) {
            const slides = document.querySelectorAll('.slideshow-slide');
            const dots = document.querySelectorAll('.slideshow-dot');
            
            if (slides.length === 0) return;
            
            // Wrap around
            if (index >= slides.length) index = 0;
            if (index < 0) index = slides.length - 1;
            
            // Remove active class from current
            slides[currentSlide].classList.remove('active');
            dots[currentSlide].classList.remove('active');
            
            // Add animating-out class for transition effect
            slides[currentSlide].classList.add('animating-out');
            
            // Update current
            currentSlide = index;
            
            // Add active class to new slide with animation
            setTimeout(() => {
                slides.forEach(s => s.classList.remove('animating-out'));
                slides[currentSlide].classList.add('animating-in');
                slides[currentSlide].classList.add('active');
                dots[currentSlide].classList.add('active');
                
                setTimeout(() => {
                    slides[currentSlide].classList.remove('animating-in');
                }, 800);
            }, 100);
            
            // Reset and start progress
            resetProgress();
        }

        function changeSlide(direction) {
            stopSlideshow();
            showSlide(currentSlide + direction);
            startSlideshow();
        }

        function goToSlide(index) {
            stopSlideshow();
            showSlide(index);
            startSlideshow();
        }

        function startSlideshow() {
            stopSlideshow();
            slideshowInterval = setInterval(() => {
                showSlide(currentSlide + 1);
            }, SLIDE_DURATION);
            startProgress();
        }

        function stopSlideshow() {
            if (slideshowInterval) {
                clearInterval(slideshowInterval);
            }
            if (progressInterval) {
                clearInterval(progressInterval);
            }
        }

        function startProgress() {
            const progress = document.getElementById('slideshowProgress');
            if (!progress) return;
            
            let width = 0;
            const increment = 100 / (SLIDE_DURATION / 50); // Update every 50ms
            
            progressInterval = setInterval(() => {
                width += increment;
                if (width >= 100) width = 0;
                progress.style.width = width + '%';
            }, 50);
        }

        function resetProgress() {
            const progress = document.getElementById('slideshowProgress');
            if (progress) {
                progress.style.width = '0%';
            }
        }

        // Scroll animations
        function initScrollAnimations() {
            const sections = document.querySelectorAll('.cv-section');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            });
            
            sections.forEach(section => {
                observer.observe(section);
            });
            
            // Trigger initial visible sections
            setTimeout(() => {
                sections.forEach(section => {
                    const rect = section.getBoundingClientRect();
                    if (rect.top < window.innerHeight) {
                        section.classList.add('visible');
                    }
                });
            }, 100);
        }

        // Back to top button
        function initBackToTop() {
            const backToTop = document.getElementById('backToTop');
            
            window.addEventListener('scroll', () => {
                if (window.pageYOffset > 300) {
                    backToTop.classList.add('visible');
                } else {
                    backToTop.classList.remove('visible');
                }
            });
        }

        // Load tool data
        async function loadTool() {
            const params = new URLSearchParams(window.location.search);
            const toolId = params.get('id') || params.get('slug');

            if (!toolId) {
                document.getElementById('tool-cv').innerHTML = `
                    <div class="tool-error">
                        <h2><i class="fas fa-exclamation-triangle"></i> Tool Not Found</h2>
                        <p>No tool ID provided. <a href="index.html">Back to directory</a></p>
                    </div>
                `;
                return;
            }

            try {
                const [tools1, tools2, tools3] = await Promise.all([
                    fetch('assets/data/tools1.json').then(r => r.json()).catch(() => []),
                    fetch('assets/data/tools2.json').then(r => r.json()).catch(() => []),
                    fetch('assets/data/tools3.json').then(r => r.json()).catch(() => [])
                ]);

                const allTools = [...tools1, ...tools2, ...tools3];
                const tool = allTools.find(t => t.id === toolId || t.slug === toolId);

                if (!tool) {
                    document.getElementById('tool-cv').innerHTML = `
                        <div class="tool-error">
                            <h2><i class="fas fa-exclamation-triangle"></i> Tool Not Found</h2>
                            <p>"${toolId}" not found. <a href="index.html">Back to directory</a></p>
                        </div>
                    `;
                    return;
                }

                renderTool(tool);
            } catch (error) {
                console.error('Error loading tool:', error);
                document.getElementById('tool-cv').innerHTML = `
                    <div class="tool-error">
                        <h2><i class="fas fa-exclamation-triangle"></i> Error</h2>
                        <p>Failed to load tool information.</p>
                    </div>
                `;
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadTool();
            initBackToTop();
        });
    </script>
</body>
</html>
